# Токен бота из @BotFather — ОБЯЗАТЕЛЕН в продакшене (проверка подписи initData)
BOT_TOKEN=123456:ABC-DEF...

# Telegram ID администраторов через запятую — получают role=admin при входе
ADMIN_TG_IDS=11111111,22222222

# Порт HTTP-сервера
PORT=3000

# Путь к файлу БД SQLite
DB_PATH=./data/club.db

# Максимальный возраст initData в секундах (24 часа)
AUTH_MAX_AGE_SEC=86400

# 1 = режим разработки БЕЗ Telegram: личность берётся из заголовка x-dev-tg-id.
# НИКОГДА не включать в продакшене.
DEV_AUTH=0

# Разрешённый origin для CORS в dev (vite). В проде фронт отдаётся этим же сервером.
CORS_ORIGIN=http://localhost:5173
